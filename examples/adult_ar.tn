// TN619 — Arabic surface syntax (compiles to the SAME AST as adult_en.tn)
دالة رئيسي() {
    دع العمر = ٢٠

    اذا العمر > ١٨ {
        اطبع("بالغ")
    } وإلا {
        اطبع("قاصر")
    }

    متغير المجموع = ٠
    لكل ع في ١..٦ {
        المجموع = المجموع + ع
    }
    اطبع("المجموع ١..٥ ="، المجموع)

    اطبع("المضروب(٥) ="، مضروب(٥))
}

دالة مضروب(ن: عدد) -> عدد {
    اذا ن <= ١ {
        ١
    } وإلا {
        ن * مضروب(ن - ١)
    }
}
