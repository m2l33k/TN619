// TN619 — methods and associated functions (Arabic surface)
هيكل نقطة { س: عدد، ص: عدد }

تطبيق نقطة {
    دالة جديد(س: عدد، ص: عدد) -> نقطة {
        نقطة { س: س، ص: ص }
    }
    دالة مجموع(&الذات) -> عدد {
        الذات.س + الذات.ص
    }
    دالة منقول(&الذات، دس: عدد) -> نقطة {
        نقطة { س: الذات.س + دس، ص: الذات.ص }
    }
}

دالة رئيسي() {
    دع ن = نقطة::جديد(٣، ٤)
    اطبع("ن.مجموع:"، ن.مجموع())

    دع م = ن.منقول(١٠)
    اطبع("م.س:"، م.س، "م.مجموع:"، م.مجموع())
}
