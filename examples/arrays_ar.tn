// TN619 — المصفوفات: القيم، الفهرسة، التعديل، التكرار (السطح العربي)
دالة مجموع(س: [عدد]) -> عدد {
    متغير الكل = ٠
    لكل ع في س {
        الكل = الكل + ع
    }
    الكل
}

دالة رئيسي() {
    دع الأرقام = [١٠، ٢٠، ٣٠]
    اطبع("الأول:", الأرقام[٠])
    اطبع("الطول:", الأرقام.طول())
    اطبع("المجموع:", مجموع(الأرقام))

    متغير المكدس = [١، ٢]
    المكدس.أضف(٣)
    اطبع("بعد الإضافة:", المكدس)
    دع الأعلى = المكدس.اسحب()
    اطبع("المسحوب:", الأعلى, "الآن:", المكدس)
}
